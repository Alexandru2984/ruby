<%= form_with(model: bookmark, class: "contents") do |form| %>
  <% if bookmark.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-700 dark:bg-red-950 dark:text-red-300 px-4 py-3 font-medium rounded-lg mt-5">
      <h2><%= pluralize(bookmark.errors.count, "error") %> prohibited this bookmark from being saved:</h2>

      <ul class="list-disc ml-6 mt-1 font-normal">
        <% bookmark.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :url, class: "block text-sm font-medium" %>
    <%= form.text_field :url, required: true, autofocus: bookmark.new_record?, placeholder: "https://example.com/article", class: input_classes(errored: bookmark.errors[:url].any?) %>
    <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">The only required field — title and description are fetched automatically if left blank.</p>
  </div>

  <div class="my-5">
    <%= form.label :title, class: "block text-sm font-medium" %>
    <%= form.text_field :title, class: input_classes(errored: bookmark.errors[:title].any?) %>
  </div>

  <div class="my-5">
    <%= form.label :description, class: "block text-sm font-medium" %>
    <%= form.textarea :description, rows: 4, class: input_classes(errored: bookmark.errors[:description].any?) %>
  </div>

  <div class="my-5">
    <%= form.label :tag_list, "Tags", class: "block text-sm font-medium" %>
    <%= form.text_field :tag_list, placeholder: "rails, ruby, reading-list", class: input_classes(errored: bookmark.errors[:tag_list].any?) %>
    <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">Separate tags with commas.</p>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto #{button_classes(:primary)}" %>
  </div>
<% end %>
