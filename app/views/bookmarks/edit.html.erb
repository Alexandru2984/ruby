<% content_for :title, "Editing bookmark" %>

<div class="mx-auto w-full max-w-2xl">
  <h1 class="font-bold text-3xl">Editing bookmark</h1>

  <%= render "form", bookmark: @bookmark %>

  <div class="flex gap-4 text-sm">
    <%= link_to "Show this bookmark", @bookmark, class: "text-zinc-500 dark:text-zinc-400 hover:text-blue-600 dark:hover:text-blue-400" %>
    <%= link_to "Back to bookmarks", bookmarks_path, class: "text-zinc-500 dark:text-zinc-400 hover:text-blue-600 dark:hover:text-blue-400" %>
  </div>
</div>
