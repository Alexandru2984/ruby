<div id="<%= dom_id bookmark %>" class="flex gap-4 rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-5 shadow-sm">
  <% if local_assigns.fetch(:selectable, false) %>
    <input type="checkbox" name="ids[]" value="<%= bookmark.id %>" form="bulk-form" aria-label="Select bookmark"
           data-action="selection#refresh" data-selection-target="checkbox"
           class="mt-2 size-4 shrink-0 accent-blue-600 cursor-pointer">
  <% end %>
  <div class="shrink-0 mt-0.5">
    <% if bookmark.favicon_url.present? %>
      <img src="<%= bookmark.favicon_url %>" alt="" width="32" height="32" loading="lazy" class="w-8 h-8 rounded" onerror="this.style.display='none'">
    <% else %>
      <div class="w-8 h-8 rounded bg-blue-100 text-blue-700 dark:bg-blue-950 dark:text-blue-300 flex items-center justify-center font-bold uppercase" aria-hidden="true"><%= bookmark.display_title.first %></div>
    <% end %>
  </div>

  <div class="flex-1 min-w-0">
    <div class="flex items-start justify-between gap-3">
      <h2 class="font-semibold text-lg leading-snug break-words">
        <%= link_to bookmark.display_title, visit_bookmark_path(bookmark), target: "_blank", rel: "noopener", class: "hover:text-blue-600 dark:hover:text-blue-400" %>
      </h2>
      <%= button_to toggle_favorite_bookmark_path(bookmark), method: :patch, form_class: "shrink-0",
            class: "cursor-pointer text-xl leading-none #{bookmark.favorite? ? "text-amber-400 hover:text-amber-500" : "text-zinc-300 dark:text-zinc-600 hover:text-amber-400"}",
            title: bookmark.favorite? ? "Remove from favorites" : "Add to favorites",
            "aria-label": "Toggle favorite" do %>&#9733;<% end %>
    </div>

    <p class="text-sm text-zinc-500 dark:text-zinc-400 truncate">
      <%= bookmark.host %>
      <% if bookmark.visits_count.positive? %> · <%= pluralize(bookmark.visits_count, "visit") %><% end %>
      · added <%= time_ago_in_words(bookmark.created_at) %> ago
      <% if bookmark.archived? %> · <span class="text-amber-600 dark:text-amber-500 font-medium">archived</span><% end %>
      <% if bookmark.link_broken? %> · <span class="text-red-600 dark:text-red-400 font-medium" title="Last check failed<%= " on #{bookmark.link_checked_at.to_date}" if bookmark.link_checked_at %>">link broken</span><% end %>
    </p>

    <% if bookmark.description.present? %>
      <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400 line-clamp-2"><%= bookmark.description %></p>
    <% end %>

    <div class="mt-3 flex flex-wrap items-center gap-x-2 gap-y-2 text-sm">
      <% bookmark.tags.sort_by(&:name).each do |tag| %>
        <%= link_to tag.name, bookmarks_path(tag: tag.name), class: "text-xs font-medium bg-blue-50 text-blue-700 dark:bg-blue-950 dark:text-blue-300 rounded-full px-2.5 py-1 hover:bg-blue-100 dark:hover:bg-blue-900" %>
      <% end %>

      <span class="ml-auto flex items-center gap-1 text-zinc-500 dark:text-zinc-400">
        <button type="button" data-controller="clipboard" data-clipboard-text-value="<%= bookmark.url %>" data-action="clipboard#copy"
                class="rounded-md px-2 py-1 hover:bg-zinc-100 dark:hover:bg-zinc-800 font-medium cursor-pointer">Copy URL</button>
        <%= link_to "Details", bookmark, class: "rounded-md px-2 py-1 hover:bg-zinc-100 dark:hover:bg-zinc-800 font-medium" %>
        <%= link_to "Edit", edit_bookmark_path(bookmark), class: "rounded-md px-2 py-1 hover:bg-zinc-100 dark:hover:bg-zinc-800 font-medium" %>
        <% if bookmark.archived? %>
          <%= button_to "Restore", unarchive_bookmark_path(bookmark), method: :patch, class: "rounded-md px-2 py-1 hover:bg-zinc-100 dark:hover:bg-zinc-800 font-medium cursor-pointer" %>
          <%= button_to "Delete", bookmark, method: :delete, data: { turbo_confirm: "Permanently delete this bookmark?" }, class: "rounded-md px-2 py-1 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-950 font-medium cursor-pointer" %>
        <% else %>
          <%= button_to "Archive", archive_bookmark_path(bookmark), method: :patch, class: "rounded-md px-2 py-1 hover:bg-zinc-100 dark:hover:bg-zinc-800 font-medium cursor-pointer" %>
        <% end %>
      </span>
    </div>
  </div>
</div>
