<% content_for :title, @bookmark.display_title %>

<div class="mx-auto w-full max-w-3xl">
  <%= link_to "← Back to bookmarks", bookmarks_path, class: "text-sm text-zinc-500 dark:text-zinc-400 hover:text-blue-600 dark:hover:text-blue-400" %>

  <div class="mt-4">
    <%= render @bookmark %>
  </div>

  <dl class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-5">
    <div>
      <dt class="font-medium text-zinc-500 dark:text-zinc-400">URL</dt>
      <dd class="mt-1 break-all"><%= link_to @bookmark.url, visit_bookmark_path(@bookmark), target: "_blank", rel: "noopener", class: "text-blue-600 dark:text-blue-400 hover:underline" %></dd>
    </div>
    <div>
      <dt class="font-medium text-zinc-500 dark:text-zinc-400">Added</dt>
      <dd class="mt-1"><%= @bookmark.created_at.to_fs(:long) %></dd>
    </div>
    <div>
      <dt class="font-medium text-zinc-500 dark:text-zinc-400">Visits</dt>
      <dd class="mt-1"><%= @bookmark.visits_count %></dd>
    </div>
    <div>
      <dt class="font-medium text-zinc-500 dark:text-zinc-400">Last visited</dt>
      <dd class="mt-1"><%= @bookmark.last_visited_at ? @bookmark.last_visited_at.to_fs(:long) : "never" %></dd>
    </div>
  </dl>

  <div class="mt-6 flex flex-col sm:flex-row gap-2">
    <%= link_to "Edit this bookmark", edit_bookmark_path(@bookmark), class: button_classes(:secondary) %>
    <%= button_to "Destroy this bookmark", @bookmark, method: :delete, form_class: "contents", class: "w-full sm:w-auto #{button_classes(:danger)}", data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>
