<% content_for :title, "Bookmarks" %>

<div class="w-full">
  <div class="flex flex-wrap justify-between items-center gap-3">
    <h1 class="font-bold text-3xl">Bookmarks</h1>

    <span class="text-sm text-zinc-500 dark:text-zinc-400">
      <%= link_to "Import", new_import_path, class: "underline hover:no-underline" %>
      · Export:
      <%= link_to "HTML", export_bookmarks_path(format: :html), class: "underline hover:no-underline" %>
      <%= link_to "JSON", export_bookmarks_path(format: :json), class: "underline hover:no-underline" %>
      <%= link_to "CSV", export_bookmarks_path(format: :csv), class: "underline hover:no-underline" %>
    </span>
  </div>

  <div class="mt-6">
    <%= form_with url: bookmarks_path, method: :get, class: "flex flex-col sm:flex-row gap-2" do |form| %>
      <%= form.search_field :q, value: params[:q], placeholder: "Search bookmarks…", class: "block rounded-md border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 focus:outline-blue-600 px-3 py-2 w-full shadow-sm" %>
      <%= form.hidden_field :tag, value: params[:tag] %>
      <%= form.hidden_field :filter, value: params[:filter] %>
      <div class="flex gap-2">
        <%= form.select :sort, options_for_select([ [ "Newest", "newest" ], [ "Oldest", "oldest" ], [ "Title", "title" ], [ "Most visited", "most_visited" ] ], params[:sort]), {}, class: "rounded-md border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 shadow-sm" %>
        <%= form.submit "Search", class: "rounded-md px-3.5 py-2 bg-zinc-100 hover:bg-zinc-200 dark:bg-zinc-800 dark:hover:bg-zinc-700 font-medium cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <div class="mt-4 flex flex-wrap items-center gap-2 text-sm font-medium">
    <%= link_to "All", bookmarks_path(tag: params[:tag], q: params[:q]), class: ["rounded-full px-3 py-1", params[:filter].blank? ? "bg-blue-600 text-white" : "bg-zinc-100 hover:bg-zinc-200 dark:bg-zinc-800 dark:hover:bg-zinc-700"] %>
    <%= link_to "Favorites", bookmarks_path(filter: "favorites", tag: params[:tag], q: params[:q]), class: ["rounded-full px-3 py-1", params[:filter] == "favorites" ? "bg-blue-600 text-white" : "bg-zinc-100 hover:bg-zinc-200 dark:bg-zinc-800 dark:hover:bg-zinc-700"] %>
    <%= link_to "Archived", bookmarks_path(filter: "archived", tag: params[:tag], q: params[:q]), class: ["rounded-full px-3 py-1", params[:filter] == "archived" ? "bg-blue-600 text-white" : "bg-zinc-100 hover:bg-zinc-200 dark:bg-zinc-800 dark:hover:bg-zinc-700"] %>

    <% if params[:tag].present? %>
      <span class="rounded-full px-3 py-1 bg-blue-50 text-blue-700 dark:bg-blue-950 dark:text-blue-300">
        tag: <%= params[:tag] %>
        <%= link_to "×", bookmarks_path(filter: params[:filter], q: params[:q]), class: "font-bold ml-1", "aria-label": "Clear tag filter" %>
      </span>
    <% end %>

    <% if @pagy.count.positive? %>
      <span class="ml-auto text-zinc-400 dark:text-zinc-500 font-normal"><%= pluralize(@pagy.count, "bookmark") %></span>
    <% end %>
  </div>

  <div id="bookmarks" class="mt-6 space-y-4">
    <% if @bookmarks.any? %>
      <%= render @bookmarks %>
    <% elsif params[:q].present? || params[:tag].present? || params[:filter].present? %>
      <div class="text-center py-16 text-zinc-500 dark:text-zinc-400">
        <p class="text-lg font-medium">Nothing matches those filters.</p>
        <p class="mt-2"><%= link_to "Clear filters", bookmarks_path, class: "text-blue-600 dark:text-blue-400 underline hover:no-underline" %></p>
      </div>
    <% else %>
      <div class="text-center py-16">
        <p class="text-4xl" aria-hidden="true">🔖</p>
        <p class="mt-4 text-lg font-medium">Save your first bookmark</p>
        <p class="mt-1 text-zinc-500 dark:text-zinc-400">Keep every link you care about in one place — tagged, searchable, yours.</p>
        <div class="mt-6 flex justify-center gap-3">
          <%= link_to "New bookmark", new_bookmark_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium" %>
          <%= link_to "Import from browser", new_import_path, class: "rounded-md px-3.5 py-2.5 bg-zinc-100 hover:bg-zinc-200 dark:bg-zinc-800 dark:hover:bg-zinc-700 font-medium" %>
        </div>
      </div>
    <% end %>
  </div>

  <%= render "shared/pagination", pagy: @pagy %>
</div>
