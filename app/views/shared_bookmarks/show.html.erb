<% content_for :title, "Shared favorites" %>
<% content_for :head, auto_discovery_link_tag(:rss, shared_bookmarks_url(token: @owner.public_token, format: :rss), title: "Shared favorites") %>

<div class="w-full">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h1 class="font-bold text-3xl">Shared favorites</h1>
    <%= link_to "RSS feed", shared_bookmarks_path(token: @owner.public_token, format: :rss), class: "text-sm text-zinc-500 dark:text-zinc-400 underline hover:no-underline" %>
  </div>
  <p class="mt-2 text-zinc-500 dark:text-zinc-400">A hand-picked collection of favorite links.</p>

  <div class="mt-6 space-y-4">
    <% if @bookmarks.any? %>
      <% @bookmarks.each do |bookmark| %>
        <div class="flex gap-4 rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-5 shadow-sm">
          <div class="shrink-0 mt-0.5">
            <% if bookmark.favicon_url.present? %>
              <img src="<%= bookmark.favicon_url %>" alt="" width="32" height="32" loading="lazy" class="w-8 h-8 rounded" onerror="this.style.display='none'">
            <% else %>
              <div class="w-8 h-8 rounded bg-blue-100 text-blue-700 dark:bg-blue-950 dark:text-blue-300 flex items-center justify-center font-bold uppercase" aria-hidden="true"><%= bookmark.display_title.first %></div>
            <% end %>
          </div>

          <div class="flex-1 min-w-0">
            <h2 class="font-semibold text-lg leading-snug break-words">
              <%= link_to bookmark.display_title, bookmark.url, target: "_blank", rel: "noopener nofollow", class: "hover:text-blue-600 dark:hover:text-blue-400" %>
            </h2>
            <p class="text-sm text-zinc-500 dark:text-zinc-400 truncate"><%= bookmark.host %></p>

            <% if bookmark.description.present? %>
              <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400 line-clamp-2"><%= bookmark.description %></p>
            <% end %>

            <% if bookmark.tags.any? %>
              <div class="mt-3 flex flex-wrap gap-2">
                <% bookmark.tags.sort_by(&:name).each do |tag| %>
                  <span class="text-xs font-medium bg-blue-50 text-blue-700 dark:bg-blue-950 dark:text-blue-300 rounded-full px-2.5 py-1"><%= tag.name %></span>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center py-16 text-zinc-500 dark:text-zinc-400">Nothing shared yet.</p>
    <% end %>
  </div>

  <%= render "shared/pagination", pagy: @pagy %>
</div>
