<% content_for :title, "Sign up" %>

<div class="mx-auto w-full max-w-md">
  <h1 class="font-bold text-3xl">Sign up</h1>

  <%= form_with model: @user, url: registration_path, class: "contents" do |form| %>
    <% if @user.errors.any? %>
      <div class="bg-red-50 text-red-700 dark:bg-red-950 dark:text-red-300 px-4 py-3 mt-5 font-medium rounded-lg" id="error_explanation">
        <ul class="list-disc ml-4">
          <% @user.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="my-5">
      <%= form.label :email_address, class: "block text-sm font-medium" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "you@example.com", class: input_classes(errored: @user.errors[:email_address].any?) %>
    </div>

    <div class="my-5">
      <%= form.label :password, class: "block text-sm font-medium" %>
      <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "At least 8 characters", maxlength: 72, class: input_classes(errored: @user.errors[:password].any?) %>
    </div>

    <div class="my-5">
      <%= form.label :password_confirmation, class: "block text-sm font-medium" %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Repeat your password", maxlength: 72, class: input_classes(errored: @user.errors[:password_confirmation].any?) %>
    </div>

    <div class="sm:flex sm:items-center sm:gap-4">
      <%= form.submit "Create account", class: "w-full sm:w-auto #{button_classes(:primary)}" %>

      <div class="mt-4 text-sm text-zinc-500 dark:text-zinc-400 sm:mt-0">
        Already have an account? <%= link_to "Sign in", new_session_path, class: "underline hover:no-underline" %>
      </div>
    </div>
  <% end %>
</div>
