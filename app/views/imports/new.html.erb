<% content_for :title, "Import bookmarks" %>

<div class="mx-auto md:w-2/3 w-full max-w-xl">
  <h1 class="font-bold text-4xl">Import bookmarks</h1>

  <p class="mt-4 text-gray-600">
    Upload a bookmarks HTML file exported from Chrome, Firefox, Safari or any
    other app that speaks the standard bookmarks format. Duplicates are
    skipped automatically.
  </p>

  <%= form_with url: import_path, method: :post, multipart: true, class: "mt-6" do |form| %>
    <%= form.file_field :file, accept: ".html,text/html", required: true, class: "block w-full text-sm text-gray-600 file:mr-4 file:rounded-md file:border-0 file:bg-blue-600 file:px-4 file:py-2.5 file:font-medium file:text-white hover:file:bg-blue-500 file:cursor-pointer" %>
    <%= form.submit "Import", class: "mt-5 rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>
    <%= link_to "Cancel", bookmarks_path, class: "ml-2 text-gray-600 underline hover:no-underline" %>
  <% end %>
</div>
