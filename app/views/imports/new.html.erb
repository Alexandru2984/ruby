<% content_for :title, "Import bookmarks" %>

<div class="mx-auto w-full max-w-xl">
  <h1 class="font-bold text-3xl">Import bookmarks</h1>

  <p class="mt-4 text-zinc-600 dark:text-zinc-400">
    Upload a bookmarks HTML file exported from Chrome, Firefox, Safari or any
    other app that speaks the standard bookmarks format. Duplicates are
    skipped automatically.
  </p>

  <%= form_with url: import_path, method: :post, multipart: true, class: "mt-6" do |form| %>
    <%= form.file_field :file, accept: ".html,text/html", required: true, class: "block w-full text-sm text-zinc-600 dark:text-zinc-400 file:mr-4 file:rounded-md file:border-0 file:bg-blue-600 file:px-4 file:py-2.5 file:font-medium file:text-white hover:file:bg-blue-500 file:cursor-pointer" %>

    <div class="mt-5 flex items-center gap-3">
      <%= form.submit "Import", class: button_classes(:primary) %>
      <%= link_to "Cancel", bookmarks_path, class: "text-zinc-500 dark:text-zinc-400 underline hover:no-underline" %>
    </div>
  <% end %>
</div>
