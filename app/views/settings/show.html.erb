<% content_for :title, "Settings" %>

<div class="mx-auto w-full max-w-2xl space-y-8">
  <h1 class="font-bold text-3xl">Settings</h1>

  <section class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-5">
    <h2 class="font-semibold text-lg">Account</h2>
    <dl class="mt-3 text-sm space-y-2">
      <div class="flex gap-2">
        <dt class="text-zinc-500 dark:text-zinc-400 w-32">Email</dt>
        <dd><%= Current.user.email_address %></dd>
      </div>
      <div class="flex gap-2">
        <dt class="text-zinc-500 dark:text-zinc-400 w-32">Member since</dt>
        <dd><%= Current.user.created_at.to_date.to_fs(:long) %></dd>
      </div>
      <div class="flex gap-2">
        <dt class="text-zinc-500 dark:text-zinc-400 w-32">Bookmarks</dt>
        <dd><%= Current.user.bookmarks.count %></dd>
      </div>
    </dl>
  </section>

  <section class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-5">
    <h2 class="font-semibold text-lg">Bookmarklet</h2>
    <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">
      Drag this button to your browser's bookmarks bar. Clicking it on any page
      opens a prefilled "save bookmark" window.
    </p>
    <p class="mt-4">
      <a href="<%= bookmarklet_javascript %>" class="<%= button_classes(:primary) %>" onclick="return false" title="Drag me to your bookmarks bar">🔖 Save to Bookmarks</a>
    </p>
  </section>

  <section class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-5">
    <h2 class="font-semibold text-lg">API access</h2>
    <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">
      Authenticate API requests with <code class="font-mono bg-zinc-100 dark:bg-zinc-800 px-1 rounded">Authorization: Bearer &lt;token&gt;</code>.
    </p>

    <% if Current.user.api_token.present? %>
      <div class="mt-4 flex items-center gap-2">
        <code id="api-token" class="font-mono text-sm bg-zinc-100 dark:bg-zinc-800 rounded-md px-3 py-2 break-all"><%= Current.user.api_token %></code>
        <button type="button" data-controller="clipboard" data-clipboard-text-value="<%= Current.user.api_token %>" data-action="clipboard#copy"
                class="shrink-0 rounded-md px-2 py-1 text-sm hover:bg-zinc-100 dark:hover:bg-zinc-800 font-medium cursor-pointer">Copy</button>
      </div>

      <pre class="mt-4 text-xs bg-zinc-100 dark:bg-zinc-800 rounded-md px-3 py-2 overflow-x-auto"><code>curl -H "Authorization: Bearer <%= Current.user.api_token %>" <%= api_v1_bookmarks_url %></code></pre>

      <div class="mt-4 flex gap-2">
        <%= button_to "Regenerate", api_token_path, method: :post, data: { turbo_confirm: "The current token will stop working. Continue?" }, class: button_classes(:secondary) %>
        <%= button_to "Revoke", api_token_path, method: :delete, data: { turbo_confirm: "Revoke API access?" }, class: button_classes(:danger) %>
      </div>
    <% else %>
      <div class="mt-4">
        <%= button_to "Generate API token", api_token_path, method: :post, class: button_classes(:primary) %>
      </div>
    <% end %>
  </section>

  <section class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-5">
    <h2 class="font-semibold text-lg">Public sharing</h2>
    <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">
      Share your ★ favorites (excluding archived ones) with anyone through a
      secret read-only link. Turning sharing off or regenerating kills the old link.
    </p>

    <% if Current.user.sharing_enabled? %>
      <div class="mt-4 flex items-center gap-2">
        <code class="font-mono text-sm bg-zinc-100 dark:bg-zinc-800 rounded-md px-3 py-2 break-all"><%= shared_bookmarks_url(token: Current.user.public_token) %></code>
        <button type="button" data-controller="clipboard" data-clipboard-text-value="<%= shared_bookmarks_url(token: Current.user.public_token) %>" data-action="clipboard#copy"
                class="shrink-0 rounded-md px-2 py-1 text-sm hover:bg-zinc-100 dark:hover:bg-zinc-800 font-medium cursor-pointer">Copy</button>
      </div>

      <div class="mt-4 flex gap-2">
        <%= button_to "Regenerate link", public_share_path, method: :post, data: { turbo_confirm: "The current link will stop working. Continue?" }, class: button_classes(:secondary) %>
        <%= button_to "Turn off", public_share_path, method: :delete, data: { turbo_confirm: "Disable public sharing?" }, class: button_classes(:danger) %>
      </div>
    <% else %>
      <div class="mt-4">
        <%= button_to "Enable public sharing", public_share_path, method: :post, class: button_classes(:primary) %>
      </div>
    <% end %>
  </section>

  <section class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-5">
    <h2 class="font-semibold text-lg">Your data</h2>
    <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">
      Everything you save here is yours to take anywhere.
    </p>
    <div class="mt-4 flex flex-wrap gap-2 text-sm">
      <%= link_to "Export HTML", export_bookmarks_path(format: :html), class: button_classes(:secondary) %>
      <%= link_to "Export JSON", export_bookmarks_path(format: :json), class: button_classes(:secondary) %>
      <%= link_to "Export CSV", export_bookmarks_path(format: :csv), class: button_classes(:secondary) %>
      <%= link_to "Import…", new_import_path, class: button_classes(:secondary) %>
    </div>
  </section>
</div>
