<% flash.each do |type, message| %>
  <% next if message.blank? %>
  <div id="<%= type %>" role="alert" data-controller="removals"
       class="<%= type.to_s == "alert" ? "bg-red-50 text-red-700 dark:bg-red-950 dark:text-red-300" : "bg-green-50 text-green-700 dark:bg-green-950 dark:text-green-300" %> mb-6 flex items-center justify-between gap-4 rounded-lg px-4 py-3 font-medium">
    <span><%= message %></span>
    <button type="button" data-action="removals#remove" aria-label="Dismiss" class="text-lg leading-none opacity-60 hover:opacity-100 cursor-pointer">&times;</button>
  </div>
<% end %>
